root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
end_of_line = lf
indent_style = space
max_line_length = 100
trim_trailing_whitespace = false

[*.xml]
max_line_length = off


[*.{kt,kts}]
indent_style = tab
indent_size = 4
max_line_length = off

