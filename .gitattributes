# Normalize text files consistently across contributors and CI.
* text=auto

# Android / Kotlin sources should remain LF regardless of local Git settings.
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.toml text eol=lf
*.pro text eol=lf
*.md text eol=lf
*.txt text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
NOTICE text eol=lf
README.md text eol=lf
gradlew text eol=lf

# Windows-native scripts should keep CRLF for local shell ergonomics.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common committed binaries should not be line-normalized.
*.jar binary
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary

