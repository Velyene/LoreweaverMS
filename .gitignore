# Personal / machine-specific IDE state (do not share)
/.idea/appInsightsSettings.xml
/.idea/deviceManager.xml
/.idea/emulatorDisplays.xml
/.idea/markdown.xml
/.idea/errors/
/.idea/sessions/
/.idea/shelf/
/.idea/dataSources/
/.idea/dataSources.local.xml
/.idea/sqlDataSources.xml
/.idea/dynamic.xml
/.idea/usage.statistics.xml
# Keep: `.idea/gradle.xml`, `.idea/compiler.xml`, `.idea/misc.xml`,
#       `.idea/runConfigurations.xml`, `.idea/inspectionProfiles/`,
#       `.idea/codeStyles/`, `.idea/dictionaries/`, `.idea/.gitignore`, `.idea/.name`,
#       `.idea/AndroidProjectSystem.xml`, `.idea/jsonCatalog.xml`

