<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Cloud backup keeps only lightweight preferences; user-authored campaign data stays device-local. -->
        <include
            domain="sharedpref"
            path="reference_preferences.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Device-to-device transfer preserves the full local campaign store. -->
        <include
            domain="database"
            path="loreweaver_database" />
        <include
            domain="database"
            path="loreweaver_database-wal" />
        <include
            domain="database"
            path="loreweaver_database-shm" />
        <include
            domain="database"
            path="loreweaver_database-journal" />
        <include
            domain="sharedpref"
            path="reference_preferences.xml" />
    </device-transfer>
</data-extraction-rules>
