<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Loreweaver talisman gem — three concentric diamonds.
        Safe zone: 18–90 dp (72dp square centred in the 108dp canvas).
        Colours from Color.kt:
          LoreTeal  #64C9C9
          LoreGold  #C9A24D
          AppBg     #120E16
    -->

    <!-- Layer 1 — outer glow diamond (LoreTeal at 20% opacity) -->
    <path
        android:fillColor="#3364C9C9"
        android:pathData="M54,18 L90,54 L54,90 L18,54 Z" />

    <!-- Layer 2 — outer diamond border in LoreGold -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,18 L90,54 L54,90 L18,54 Z"
        android:strokeWidth="2"
        android:strokeColor="#C9A24D" />

    <!-- Layer 3 — main solid gem in LoreTeal -->
    <path
        android:fillColor="#64C9C9"
        android:pathData="M54,30 L76,54 L54,78 L32,54 Z" />

    <!-- Layer 4 — gem facet lines: inner corners → outer corners -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,30 L54,18 M76,54 L90,54 M54,78 L54,90 M32,54 L18,54"
        android:strokeWidth="1.5"
        android:strokeColor="#C9A24D" />

    <!-- Layer 5 — inner gem border (dark) for depth -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,30 L76,54 L54,78 L32,54 Z"
        android:strokeWidth="1"
        android:strokeColor="#120E16" />

    <!-- Layer 6 — centre accent diamond in LoreGold -->
    <path
        android:fillColor="#C9A24D"
        android:pathData="M54,44 L64,54 L54,64 L44,54 Z" />

    <!-- Layer 7 — centre highlight (white at 70%) for gem sparkle -->
    <path
        android:fillColor="#B3FFFFFF"
        android:pathData="M54,48 L58,54 L54,58 L50,54 Z" />

</vector>